# Copy to .env.local and fill in.

# Slack app credentials (https://api.slack.com/apps)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# Base URL the bot fetches /data/*.yaml from (prod: https://conferences.light-laboratory.org)
CONFERENCES_DATA_URL=http://localhost:3000

# Deployed app URL, used for calendar download links and OAuth callbacks (prod: the Vercel URL)
APP_URL=http://localhost:3000

# Random secret protecting the cron endpoints
CRON_SECRET=

# Days before a deadline to post channel reminders
CHANNEL_REMINDER_DAYS=30,7,3

# Vercel KV / Upstash, from the Vercel dashboard
KV_URL=rediss://...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
REDIS_URL=rediss://...

# OpenAI key for pnpm sync:llm
OPENAI_API_KEY=
